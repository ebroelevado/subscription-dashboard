# Database is configured via Cloudflare D1 binding in wrangler.toml
# No DATABASE_URL needed for D1

# Better Auth
AUTH_SECRET="your-auth-secret-min-32-chars"
AUTH_URL="http://localhost:3000"

# Google Auth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Cloudflare R2 Storage (Conversation History)
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="your-bucket-name"
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"

# Stripe
STRIPE_SECRET_KEY="sk_test_or_sk_live_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_PREMIUM_PRICE_ID="price_your_premium_price_id"

# Security
SERVICE_CREDENTIALS_KEY="base64_32_byte_key"
CRON_SECRET="hex_64_chars_secret"

# AI Gateway
CF_ACCOUNT_ID="your-cf-account-id"
CF_AI_GATEWAY_NAME="default"
CF_AIG_TOKEN="your-cf-aig-token"
GROQ_API_KEY="your-groq-api-key"
CEREBRAS_API_KEY="your-cerebras-api-key"

# Durable Objects & Proxy
AGENT_SESSION_URL="https://your-worker.workers.dev"
USE_REMOTE_DB="true"
DB_PROXY_SECRET="your-proxy-secret"

# SES Lockdown Control
AUTH_DISABLE_SES="true"
SES_ALLOW_DYNAMIC_CODE="true"
