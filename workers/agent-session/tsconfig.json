{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["@cloudflare/workers-types/2023-07-01"],
    "baseUrl": "../../",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "../../src/**/*"],
  "exclude": ["node_modules", "../../.vercel"]
}
