generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(uuid())
  name              String?
  email             String             @unique
  emailVerified     DateTime?          @map("email_verified")
  password          String?
  image             String?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  copilotToken      String?
  currency          String             @default("EUR") @db.VarChar(10)
  disciplinePenalty Float              @default(0.5) @map("discipline_penalty")
  usageCredits       Float              @default(0.0) @map("usage_credits")
  companyName        String?            @map("company_name") @db.VarChar(100)
  whatsappSignatureMode String           @default("name") @map("whatsapp_signature_mode") @db.VarChar(20)
  accounts           Account[]
  clients           Client[]
  mutationAuditLogs MutationAuditLog[]
  plans             Plan[]
  platforms         Platform[]
  sessions          Session[]
  subscriptions     Subscription[]
  plan              UserPlan           @default(FREE)
  stripeCustomerId       String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId   String?            @unique @map("stripe_subscription_id")
  stripePriceId          String?            @map("stripe_price_id")
  stripeCurrentPeriodEnd DateTime?          @map("stripe_current_period_end")

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Platform {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  userId    String   @map("user_id")
  plans     Plan[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("platforms")
}

model Plan {
  id            String         @id @default(uuid())
  platformId    String         @map("platform_id")
  name          String         @db.VarChar(100)
  cost          Decimal        @db.Decimal(10, 2)
  maxSeats      Int?           @map("max_seats")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  userId        String         @map("user_id")
  platform      Platform       @relation(fields: [platformId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@index([userId])
  @@map("plans")
}

model Subscription {
  id                  String               @id @default(uuid())
  planId              String               @map("plan_id")
  label               String               @db.VarChar(100)
  startDate           DateTime             @map("start_date") @db.Date
  activeUntil         DateTime             @map("active_until") @db.Date
  status              SubscriptionStatus   @default(active)
  createdAt           DateTime             @default(now()) @map("created_at")
  userId              String               @map("user_id")
  masterPassword      String?              @map("master_password") @db.VarChar(100)
  masterUsername      String?              @map("master_username") @db.VarChar(100)
  ownerId             String?              @map("owner_id")
  isAutopayable       Boolean              @default(true) @map("is_autopayable")
  defaultPaymentNote  String?              @default("como pago") @map("default_payment_note")
  clientSubscriptions ClientSubscription[]
  platformRenewals    PlatformRenewal[]
  owner               Client?              @relation("SubscriptionOwner", fields: [ownerId], references: [id])
  plan                Plan                 @relation(fields: [planId], references: [id], onDelete: Cascade)
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

model Client {
  id                  String               @id @default(uuid())
  name                String               @db.VarChar(150)
  phone               String?              @db.VarChar(30)
  notes               String?
  createdAt           DateTime             @default(now()) @map("created_at")
  userId              String               @map("user_id")
  dailyPenalty        Decimal?             @map("daily_penalty") @db.Decimal(10, 4)
  daysOverdue         Int                  @default(0) @map("days_overdue")
  disciplineScore     Decimal?             @map("discipline_score") @db.Decimal(4, 2)
  healthStatus        String?              @map("health_status") @db.VarChar(50)
  clientSubscriptions ClientSubscription[]
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownedSubscriptions  Subscription[]       @relation("SubscriptionOwner")

  @@index([userId])
  @@map("clients")
}

model ClientSubscription {
  id              String                   @id @default(uuid())
  clientId        String                   @map("client_id")
  subscriptionId  String                   @map("subscription_id")
  customPrice     Decimal                  @map("custom_price") @db.Decimal(10, 2)
  activeUntil     DateTime                 @map("active_until") @db.Date
  joinedAt        DateTime                 @map("joined_at") @db.Date
  leftAt          DateTime?                @map("left_at") @db.Date
  status          ClientSubscriptionStatus @default(active)
  remainingDays   Int?                     @map("remaining_days")
  servicePassword String?                  @map("service_password") @db.VarChar(100)
  serviceUser     String?                  @map("service_user") @db.VarChar(100)
  client          Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subscription    Subscription             @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  renewalLogs     RenewalLog[]

  @@unique([clientId, subscriptionId])
  @@index([clientId])
  @@index([subscriptionId])
  @@index([status])
  @@map("client_subscriptions")
}

model RenewalLog {
  id                   String              @id @default(uuid())
  clientSubscriptionId String?             @map("client_subscription_id")
  amountPaid           Decimal             @map("amount_paid") @db.Decimal(10, 2)
  expectedAmount       Decimal             @map("expected_amount") @db.Decimal(10, 2)
  periodStart          DateTime            @map("period_start") @db.Date
  periodEnd            DateTime            @map("period_end") @db.Date
  paidOn               DateTime            @map("paid_on") @db.Date
  dueOn                DateTime            @map("due_on") @db.Date
  monthsRenewed        Int                 @default(1) @map("months_renewed")
  notes                String?
  createdAt            DateTime            @default(now()) @map("created_at")
  clientSubscription   ClientSubscription? @relation(fields: [clientSubscriptionId], references: [id])

  @@index([clientSubscriptionId])
  @@index([paidOn])
  @@map("renewal_logs")
}

model PlatformRenewal {
  id             String       @id @default(uuid())
  subscriptionId String       @map("subscription_id")
  amountPaid     Decimal      @map("amount_paid") @db.Decimal(10, 2)
  periodStart    DateTime     @map("period_start") @db.Date
  periodEnd      DateTime     @map("period_end") @db.Date
  paidOn         DateTime     @map("paid_on") @db.Date
  createdAt      DateTime     @default(now()) @map("created_at")
  notes          String?
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([paidOn])
  @@map("platform_renewals")
}

model MutationAuditLog {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  toolName       String    @map("tool_name") @db.VarChar(100)
  targetId       String?   @map("target_id")
  action         String    @db.VarChar(20)
  previousValues Json?     @map("previous_values")
  newValues      Json?     @map("new_values")
  undone         Boolean   @default(false)
  undoneAt       DateTime? @map("undone_at")
  token          String    @unique @db.VarChar(64)
  expiresAt      DateTime  @map("expires_at")
  executedAt     DateTime? @map("executed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("mutation_audit_logs")
}

enum SubscriptionStatus {
  active
  paused
}

enum ClientSubscriptionStatus {
  active
  paused
}

enum UserPlan {
  FREE
  PREMIUM
}
