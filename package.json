{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.3.10"
  },
  "scripts": {
    "dev": "next dev",
    "dev:cf": "bun run build:cf && bun run preview",
    "dev:do": "cd workers/agent-session && bun x wrangler dev --port 8787",
    "deploy:do": "cd workers/agent-session && bun x wrangler deploy",
    "build": "bun run build:vinext",
    "build:cf": "bun x @cloudflare/next-on-pages",
    "build:next": "next build",
    "preview": "bun x wrangler pages dev .vercel/output/static",
    "deploy": "bun x wrangler pages deploy .vercel/output/static",
    "start": "vinext start",
    "start:vinext": "vinext start",
    "lint": "eslint",
    "db:generate": "bun x drizzle-kit generate",
    "db:studio": "bun x drizzle-kit studio",
    "db:migrate:local": "bun x wrangler d1 migrations apply pearfect --local",
    "db:migrate:prod": "bun x wrangler d1 migrations apply pearfect",
    "auth:check": "bun scripts/repair-auth-accounts.ts",
    "auth:repair": "bun scripts/repair-auth-accounts.ts --apply",
    "db:seed": "bun scripts/seed-d1.ts",
    "db:migrate:pg-to-d1": "bun scripts/migrate-pg-to-d1.ts",
    "dev:vinext": "vinext dev --port 3000",
    "build:vinext": "vite build",
    "test:mutations": "vitest --config vitest.config.ts run tests/mutations-execute-route.test.ts tests/mutations-status-route.test.ts tests/mutation-executor-db.test.ts tests/ai-full-control-flow.test.ts",
    "test:ai": "vitest run tests/assistant-tools.test.ts tests/ai-full-control-flow.test.ts tests/hitl-flow.test.ts tests/chat-api-route.test.ts",
    "test:services": "vitest run tests/renewals-service.test.ts tests/export-import-delete.test.ts tests/r2-utils.test.ts",
    "test:all": "vitest run",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.30",
    "@ai-sdk/react": "^3.0.99",
    "@auth/drizzle-adapter": "^1.11.1",
    "@aws-sdk/client-s3": "^3.1005.0",
    "@better-fetch/fetch": "^1.1.21",
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/vite-plugin": "^1.31.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@vitejs/plugin-rsc": "^0.5.23",
    "ai": "^6.0.97",
    "ai-gateway-provider": "^3.1.2",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.6",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.34.1",
    "katex": "^0.16.10",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^9.0.0",
    "recharts": "^3.7.0",
    "rehype-katex": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "vinext": "^0.0.41",
    "vite": "^8.0.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "react-server-dom-webpack": "^19.2.5",
    "shadcn": "^4.0.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.1",
    "wrangler": "^4.77.0"
  },
  "type": "module"
}
