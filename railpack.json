{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22",
    "bun": "1.3.10"
  },
  "steps": {
    "build": {
      "commands": [
        "set -eu; bun install --frozen-lockfile; bun run build:next; mkdir -p .next/standalone/public .next/standalone/.next; cp -r public/. .next/standalone/public/; cp -r .next/static .next/standalone/.next/static"
      ],
      "deployOutputs": [
        {
          "include": [
            ".next/standalone/**"
          ]
        }
      ],
      "variables": {
        "NEXT_CPU_COUNT": "4"
      }
    }
  },
  "deploy": {
    "inputs": [
      {
        "step": "build",
        "include": [
          ".next/standalone/**"
        ]
      }
    ],
    "startCommand": "node .next/standalone/server.js",
    "variables": {
      "NODE_ENV": "production",
      "HOSTNAME": "0.0.0.0",
      "AUTH_TRUST_HOST": "true"
    }
  }
}
