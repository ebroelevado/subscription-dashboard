{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22",
    "bun": "1.3.10"
  },
  "steps": {
    "build": {
      "commands": [
        "set -eu; bun install --frozen-lockfile; bun run build:vinext; rm -rf railpack-bundle; mkdir -p railpack-bundle; cp -r dist public package.json bun.lock vite.config.ts next.config.ts postcss.config.mjs railpack-bundle/ 2>/dev/null || true"
      ],
      "deployOutputs": [
        {
          "include": [
            "railpack-bundle/**"
          ]
        }
      ],
      "variables": {
        "NEXT_CPU_COUNT": "4"
      }
    }
  },
  "deploy": {
    "inputs": [
      {
        "step": "build",
        "include": [
          "railpack-bundle/**"
        ]
      }
    ],
    "startCommand": "cd railpack-bundle && exec bunx vinext start",
    "variables": {
      "NODE_ENV": "production",
      "HOSTNAME": "0.0.0.0",
      "AUTH_TRUST_HOST": "true",
      "USE_REMOTE_DB": "true",
      "AUTH_DISABLE_SES": "true",
      "SES_ALLOW_DYNAMIC_CODE": "true"
    }
  }
}
