{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22",
    "bun": "1.3.10"
  },
  "steps": {
    "build": {
      "commands": [
        "set -eu; bun install --frozen-lockfile; bun run build:vinext"
      ],
      "deployOutputs": [
        {
          "include": [
            "dist"
          ]
        },
        {
          "include": [
            "public"
          ]
        },
        {
          "include": [
            "package.json"
          ]
        },
        {
          "include": [
            "bun.lock"
          ]
        },
        {
          "include": [
            "next.config.ts"
          ]
        }
      ],
      "variables": {
        "NEXT_CPU_COUNT": "4"
      }
    }
  },
  "deploy": {
    "inputs": [
      {
        "step": "build",
        "include": [
          "dist",
          "public",
          "package.json",
          "bun.lock",
          "next.config.ts"
        ]
      }
    ],
    "startCommand": "exec bun run start",
    "variables": {
      "NODE_ENV": "production",
      "HOSTNAME": "0.0.0.0",
      "AUTH_TRUST_HOST": "true",
      "USE_REMOTE_DB": "true",
      "AUTH_DISABLE_SES": "true",
      "SES_ALLOW_DYNAMIC_CODE": "true"
    }
  }
}
