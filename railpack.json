{
  "$schema": "https://schema.railpack.com",
  "provider": "bun",
  "packages": {
    "bun": "1.3.10"
  },
  "steps": {
    "build": {
      "commands": [
        "bun run build",
        "cp -r public .next/standalone/public",
        "cp -r .next/static .next/standalone/.next/static"
      ],
      "variables": {
        "NEXT_CPU_COUNT": "4"
      }
    }
  },
  "deploy": {
    "startCommand": "prisma migrate deploy && bun .next/standalone/server.js",
    "variables": {
      "NODE_ENV": "production",
      "HOSTNAME": "0.0.0.0",
      "AUTH_TRUST_HOST": "true"
    }
  },
  "secrets": ["DATABASE_URL"]
}
