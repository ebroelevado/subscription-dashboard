{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22",
    "bun": "1.3.10"
  },
  "steps": {
    "build": {
      "commands": [
        "bun install",
        "bun run build:next",
        "cp -r public .next/standalone/public",
        "cp -r .next/static .next/standalone/.next/static"
      ],
      "variables": {
        "NEXT_CPU_COUNT": "4"
      }
    }
  },
  "deploy": {
    "startCommand": "bun .next/standalone/server.js",
    "variables": {
      "NODE_ENV": "production",
      "HOSTNAME": "0.0.0.0",
      "AUTH_TRUST_HOST": "true"
    }
  }
}
